# EditorConfig - Consistent coding style across editors and OS
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{js,ts,jsx,tsx,json,md,yml,yaml,sh,ps1}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.sh]
end_of_line = lf

[*.ps1]
end_of_line = crlf